# openclaw-docker configuration
# copy to .env and customize

# === ai providers (all optional - configure via 'make configure') ===
# free options: run 'make configure' and choose Kimi, MiniMax OAuth, or Qwen OAuth
# paid options: set your API key below
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
# XAI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# MINIMAX_API_KEY=
# MOONSHOT_API_KEY=
# KIMI_API_KEY=
# VOLCANO_ENGINE_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# TOGETHER_API_KEY=
# HUGGINGFACE_HUB_TOKEN=

# === search/tool apis (optional) ===
# BRAVE_API_KEY=
# PERPLEXITY_API_KEY=

# === channels (optional) ===
# MATTERMOST_BOT_TOKEN=
# MATTERMOST_URL=

# === gateway (auto-configured on setup) ===
# generate token with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=
# bind to lan (0.0.0.0) inside container so docker can route to it
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
# for remote deployments: bind to tailscale ip (auto-set by cloud-init)
# OPENCLAW_BIND_IP=
