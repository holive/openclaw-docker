# openclaw-docker configuration
# copy this file to .env and customize

# === required ===
ANTHROPIC_API_KEY=

# === gateway (auto-configured on setup) ===
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=loopback

# === ai providers (optional) ===
OPENAI_API_KEY=
OPENAI_BASE_URL=

# === channels (all optional) ===
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# === security ===
OPENCLAW_MEMORY_LIMIT=1536m

# === browser automation ===
# set to true to enable chromium (increases image size)
OPENCLAW_BROWSER=false

# === build customization ===
# space-separated list of additional apt packages
EXTRA_APT_PACKAGES=

# === workspace ===
# which workspace to use (defaults to "default")
OPENCLAW_WORKSPACE=default
